{
  "app": {
    "environment": "prod",
    "debug": false,
    "log_level": "INFO"
  },
  "service": {
    "name": "youtube-rag-server",
    "version": "0.1.0",
    "host": "0.0.0.0",
    "port": 8000
  },
  "server": {
    "reload": false,
    "workers": 2
  },
  "logging": {
    "level": "INFO",
    "format": "json"
  },
  "observability": {
    "enabled": true,
    "sample_rate": 1.0,
    "langfuse": {
      "enabled": false
    }
  },
  "resources": {
    "multi_bucket": {
      "endpoint": "minio.shared-databases.svc.cluster.local:9000",
      "secure": false
    },
    "qdrant": {
      "host": "qdrant.shared-databases.svc.cluster.local",
      "port": 6333,
      "grpc_port": 6334,
      "use_ssl": false
    },
    "mongodb": {
      "uri": "mongodb://mongodb.shared-databases.svc.cluster.local:27017",
      "database": "youtube_rag",
      "server_selection_timeout_ms": 5000,
      "connect_timeout_ms": 5000,
      "ping_timeout_seconds": 5.0
    }
  },
  "blob_storage": {
    "provider": "minio",
    "endpoint": "minio.shared-databases.svc.cluster.local:9000",
    "use_ssl": false,
    "region": "us-east-1",
    "buckets": {
      "videos": "rag-videos",
      "chunks": "rag-chunks",
      "frames": "rag-frames"
    },
    "presigned_url_expiry_seconds": 3600
  },
  "vector_db": {
    "provider": "qdrant",
    "host": "qdrant.shared-databases.svc.cluster.local",
    "port": 6333,
    "grpc_port": 6334,
    "use_ssl": false
  },
  "document_db": {
    "provider": "mongodb",
    "host": "mongodb.shared-databases.svc.cluster.local",
    "port": 27017,
    "database": "youtube_rag",
    "auth_source": "admin"
  },
  "rate_limiting": {
    "enabled": true
  }
}
