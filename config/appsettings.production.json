{
  "app": {
    "environment": "production",
    "debug": false,
    "log_level": "INFO"
  },
  "server": {
    "reload": false,
    "workers": 2
  },
  "logging": {
    "level": "INFO",
    "format": "json"
  },
  "observability": {
    "enabled": true,
    "sample_rate": 1.0,
    "langfuse": {
      "enabled": true
    }
  },
  "rate_limiting": {
    "enabled": true
  }
}
